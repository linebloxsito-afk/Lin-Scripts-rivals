-- Función para crear botones
local y = 60
local function addButton(text, callback)
    local btn = Instance.new("TextButton")
    btn.Size = UDim2.new(0.9, 0, 0, 45)
    btn.Position = UDim2.new(0.05, 0, 0, y)
    btn.BackgroundColor3 = Color3.fromRGB(40, 40, 40)
    btn.Text = text
    btn.TextColor3 = Color3.new(1,1,1)
    btn.Font = Enum.Font.Gotham
    btn.TextSize = 16
    btn.Parent = Frame
    btn.MouseButton1Click:Connect(callback)
    y = y + 55
    return btn
end

-- UNLOCK ALL
addButton("🔓 UNLOCK ALL", function()
    safe(function()
        local data = LocalPlayer:FindFirstChild("PlayerData") or LocalPlayer:WaitForChild("PlayerData", 2)
        if data then
            for _, v in pairs(data:GetDescendants()) do
                if v:IsA("BoolValue") or v:IsA("IntValue") then
                    v.Value = true
                end
            end
        end
    end)
    StarterGui:SetCore("SendNotification", {Title="Lin Scripts", Text="UNLOCK ALL aplicado!", Duration=3})
end)

-- Toggles
addButton("Kill Aura: OFF", function(btn)
    KillAura = not KillAura
    btn.Text = "Kill Aura: " .. (KillAura and "ON" or "OFF")
end)

addButton("Auto Shoot: ON", function(btn)
    AutoShoot = not AutoShoot
    btn.Text = "Auto Shoot: " .. (AutoShoot and "ON" or "OFF")
end)

addButton("Silent Aim: ON", function(btn)
    SilentAim = not SilentAim
    btn.Text = "Silent Aim: " .. (SilentAim and "ON" or "OFF")
end)

addButton("Antiban: ON", function(btn)
    Antiban = not Antiban
    btn.Text = "Antiban: " .. (Antiban and "ON" or "OFF")
end)

addButton("Speed +", function()
    WalkSpeed = WalkSpeed + 4
    local hum = LocalPlayer.Character and LocalPlayer.Character:FindFirstChild("Humanoid")
    if hum then hum.WalkSpeed = WalkSpeed end
end)

addButton("Speed -", function()
    WalkSpeed = math.max(16, WalkSpeed - 4)
    local hum = LocalPlayer.Character and LocalPlayer.Character:FindFirstChild("Humanoid")
    if hum then hum.WalkSpeed = WalkSpeed end
end)

